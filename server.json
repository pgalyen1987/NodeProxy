{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.pgalyen1987/nodeproxy",
  "title": "NodeProxy Web Surface Markdown Parser",
  "description": "x402 MCP web parser: URLs to Markdown for agents. USDC on Base, Polygon, Arbitrum, Ethereum.",
  "version": "1.0.1",
  "repository": {
    "url": "https://github.com/pgalyen1987/NodeProxy",
    "source": "github"
  },
  "websiteUrl": "https://nodeproxy-production.up.railway.app",
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://nodeproxy-production.up.railway.app/mcp"
    }
  ],
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "nodeproxy-tools",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      }
    },
    {
      "registryType": "npm",
      "identifier": "@nodeproxy/langchain",
      "version": "0.1.4",
      "transport": {
        "type": "stdio"
      }
    }
  ]
}
