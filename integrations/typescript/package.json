{
  "name": "@nodeproxy/langchain",
  "version": "0.1.0",
  "description": "LangChain.js tool wrapper for the NodeProxy x402 web surface markdown parser",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["langchain", "x402", "mcp", "markdown", "web-scraping", "agents"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pgalyen1987/NodeProxy",
    "directory": "integrations/typescript"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.2.0"
  },
  "dependencies": {
    "@x402/core": "~2.17.0",
    "@x402/evm": "~2.17.0",
    "@x402/fetch": "~2.17.0",
    "viem": "^2.30.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
