PORT=4022
HOST=0.0.0.0
# Optional — Railway sets RAILWAY_PUBLIC_DOMAIN automatically; override if using a custom domain
# PUBLIC_URL=https://your-app.up.railway.app

# Wallet that receives USDC per parse call
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Price per successful parse (USDC)
PRICE_USDC=0.002

# x402 network: eip155:8453 (Base mainnet) or eip155:84532 (Sepolia testnet)
X402_NETWORK=eip155:84532

# Testnet facilitator (omit on mainnet when CDP keys are set)
FACILITATOR_URL=https://x402.org/facilitator

# Base mainnet — get keys at https://cdp.coinbase.com
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

USDC_BASE=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913

# Production guards (512MB VM: keep concurrent parses ≤ 20)
MAX_CONCURRENT_PARSES=20
RATE_LIMIT_PER_MINUTE=120
MAX_HTML_BYTES=5242880
