PORT=4022
HOST=0.0.0.0
# Optional — Railway sets RAILWAY_PUBLIC_DOMAIN automatically; override if using a custom domain
# PUBLIC_URL=https://your-app.up.railway.app

# Wallet that receives USDC per parse call (EVM)
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Solana wallet that receives USDC (base58 pubkey). Enables solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp when set.
# SOLANA_WALLET_ADDRESS=

# x402 networks (comma-separated CAIP-2 ids). Default on Base mainnet when unset:
# eip155:8453,eip155:137,eip155:42161
# + solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp when SOLANA_WALLET_ADDRESS is set
# Ethereum mainnet USDC (eip155:1) — enabled automatically when CDP keys are set.
# SOLANA_WALLET_ADDRESS=   # base58 pubkey — enables Solana mainnet USDC when set

# Price per successful parse (USDC)
PRICE_USDC=0.002

# Legacy single-network override (used when X402_NETWORKS is unset)
X402_NETWORK=eip155:84532

# Testnet facilitator (omit on mainnet when CDP keys are set)
FACILITATOR_URL=https://x402.org/facilitator

# Base mainnet — get keys at https://cdp.coinbase.com
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=

USDC_BASE=0x833589fcd6edb6e08f4c7c32d4f71b54bda02913

# Production guards (512MB VM: keep concurrent parses ≤ 20)
MAX_CONCURRENT_PARSES=20
RATE_LIMIT_PER_MINUTE=120
MAX_HTML_BYTES=5242880

# Parse cache — in-memory LRU when REDIS_URL is unset (last 10 URLs, 10 min TTL)
# CACHE_ENABLED=1
# CACHE_TTL_SECONDS=600
# CACHE_MAX_ENTRIES=10

# Rendering: auto = JSDOM first, Playwright if content is thin (SPAs)
# RENDER_ENGINE=auto
# PLAYWRIGHT_MIN_TEXT=200
# PLAYWRIGHT_WAIT_MS=2500
# PLAYWRIGHT_TIMEOUT_MS=30000

# Payment negotiation: auto (single tailored accept) or all (list every network)
# X402_PAYMENT_MODE=auto
# X402_AUTO_NETWORK=1

# PyPI publish token (upload scope)
# PYPI_TOKEN=pypi-...
#   paymentNetwork / X-Payment-Network
#   payerAddress / X-Payer-Address  (probes USDC balance across networks)
#   paymentOptions: all / X-Payment-Options: all
